# ─────────────────────────────────────────────────────────────────────────────
# TrendPilot — Variables de entorno
# Copia a .env.local y completa los valores reales.
# NUNCA subas .env.local a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Neon PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@ep-xxx.us-east-1.aws.neon.tech/trendpilot?sslmode=require

# ── Auth interno Worker → Vercel ──────────────────────────────────────────────
# Genera con: openssl rand -hex 32
WORKER_SECRET=cambia_este_valor_por_uno_seguro

# ── Claude IA (Anthropic) ─────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (DALL-E 3 para creativos) ─────────────────────────────────────────
# platform.openai.com → API Keys
# Sin este token: creativos sin imagen IA (placeholder visual)
OPENAI_API_KEY=sk-proj-...

# ── Meta Ads ──────────────────────────────────────────────────────────────────
# Sin estas variables: modo mock (campañas simuladas)
# Ver SETUP-META.md para instrucciones completas de creación de app
#
# META_APP_ID y META_APP_SECRET:
#   developers.facebook.com → Tu app → Configuración → Básica
#
# META_ADS_ACCESS_TOKEN (token de larga duración ~60 días):
#   System User: business.facebook.com → Usuarios del sistema → Generar token
#   O intercambio: GET https://graph.facebook.com/v19.0/oauth/access_token?...
#
# META_AD_ACCOUNT_ID: Solo el número (sin "act_")
#   business.facebook.com → Cuentas de anuncios → ID
#
# META_PAGE_ID: Tu página de Facebook → Acerca de → ID de página
#
# META_WEBHOOK_VERIFY_TOKEN: String que TÚ defines
#   Debe coincidir con lo que configures en Meta App Dashboard → Webhooks

META_APP_ID=1234567890123456
META_APP_SECRET=abcdef1234567890abcdef1234567890
META_ADS_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=123456789012345
META_PAGE_ID=123456789012345
META_WEBHOOK_VERIFY_TOKEN=trendpilot_meta_webhook_2026

# ── TikTok Ads ────────────────────────────────────────────────────────────────
# Sin estas variables: modo mock
# ads.tiktok.com/marketing_api/apps → Tu app → Access Token
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TIKTOK_ADVERTISER_ID=1234567890123456789

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886
ADMIN_WHATSAPP_NUMBER=526675039081

# ── Resend (emails transaccionales) ──────────────────────────────────────────
# resend.com → API Keys
# Sin este token: emails solo en console.log (modo dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DocuSeal (contratos digitales) ───────────────────────────────────────────
# app.docuseal.com → Configuración → API Key
# Sin estas variables: modo mock (URL de firma ficticia)
DOCUSEAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DOCUSEAL_TEMPLATE_ID=12345
DOCUSEAL_WEBHOOK_SECRET=docuseal_webhook_secret_2026

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# mercadopago.com.mx → Credenciales de tu aplicación
MERCADOPAGO_CLIENT_ID=xxxxxxxxxxxxxxxxx
MERCADOPAGO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supermetrics Marketing Analytics ─────────────────────────────────────────
# supermetrics.com → API → Keys
# Sin estas variables: modo mock (métricas simuladas realistas)
# SUPERMETRICS_DS_ACCOUNT_ID: ID de tu cuenta de Facebook Ads en Supermetrics
#   (formato numérico, el mismo que META_AD_ACCOUNT_ID)
SUPERMETRICS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPERMETRICS_DS_ACCOUNT_ID=123456789012345

# ── Motion Creative Analytics ─────────────────────────────────────────────────
# app.motionapp.com → Settings → API Keys
# Sin esta variable: modo mock (creativos de ejemplo)
MOTION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── URL de la app ─────────────────────────────────────────────────────────────
# En producción: https://www.trendpilot.marketing
# En desarrollo: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://www.trendpilot.marketing
