# ============================================================
# ContaFlow AI — .gitignore del repositorio
# Los sub-proyectos (web/, app/) tienen su propio .gitignore.
# Este archivo es solo para artefactos de nivel repo.
# ============================================================

# Config local de Claude Code — nunca commitear, contiene rutas del dev
.claude/
**/.claude/

# Docs internas privadas
STRATEGY.md

# Assets de marketing que no pertenecen al repo de código
ContaFlow_AI_Presentacion.pdf

# Scripts one-off que no son parte del proyecto
generate_pdf.py

# Secretos / env — defense in depth (los sub-proyectos ya los ignoran)
.env
.env.*
!.env.example

# Archivos del SO
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
